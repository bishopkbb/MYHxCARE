# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing — vitest
/coverage

# testing — playwright
/test-results/
/playwright-report/
/playwright/.auth/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — secrets stay local
.env*
# but commit the example and test fixtures
!.env.example
!.env.test

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# docs — all internal documentation stays local only
docs/

# claude and agent config — internal tooling, never published
CLAUDE.md
AGENTS.md
.claude