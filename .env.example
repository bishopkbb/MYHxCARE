# ============================================================
# MYHxCare HMS — Environment Variables
# ============================================================
# Copy this file to .env.local for local development.
# .env.local is gitignored — never commit real credentials.

# Go API origin only. Do not append /api/v1.
# The frontend API clients append /api/v1 internally.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Complete WebSocket endpoint.
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# Values: development | demo | staging | production
#
# development and demo enable mock data.
# staging and production communicate with the real backend.
NEXT_PUBLIC_APP_ENV=development
