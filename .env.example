# ============================================================
# MYHxCare HMS — Environment Variables
# ============================================================
# Copy this file to .env.local for local development.
# .env.local is gitignored — never commit real credentials.

# Go API origin only. Do not append /api/v1.
# The frontend API clients append /api/v1 internally.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Complete WebSocket endpoint.
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# Current values:
# - development: local mock-data development
# - demo: the only approved deployed frontend mode
#
# Reserved future values: staging | production
#
# TODO(staging/production): Enable real-backend modes only after authentication,
# REST payloads, WebSocket events, CORS/CSP configuration and environment-level
# integration tests have been completed. Each deployed environment must be
# rebuilt with its own API and WebSocket URLs.
NEXT_PUBLIC_APP_ENV=development
